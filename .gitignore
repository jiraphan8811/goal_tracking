# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
*.so

# -----------------------------------------------------------------------------
# Virtual environments
# -----------------------------------------------------------------------------
venv/
.venv/
env/
.env/
testenv/
testenv_new/
.conda/
conda-meta/

# -----------------------------------------------------------------------------
# Streamlit secrets and config
# -----------------------------------------------------------------------------
.streamlit/secrets.toml
.streamlit/*.toml

# Keep example secrets if you have one
!.streamlit/secrets_example.toml

# -----------------------------------------------------------------------------
# Environment variables and credentials
# -----------------------------------------------------------------------------
.env
.env.*
*.env

# Google service account keys
*.json
*service-account*.json
*credentials*.json
*client_secret*.json
*gcp*.json
*google*.json

# -----------------------------------------------------------------------------
# Local dashboard data fallback
# -----------------------------------------------------------------------------
data/*.csv
data/*.xlsx
data/*.xls
data/*.parquet
data/*.pkl

# Keep placeholder folder if needed
!data/.gitkeep

# -----------------------------------------------------------------------------
# Exports / generated files
# -----------------------------------------------------------------------------
exports/
output/
outputs/
downloads/
*.xlsx
*.xls
*.csv
*.zip

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
*.log
logs/
debug.log

# -----------------------------------------------------------------------------
# OS / editor files
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

.vscode/
.idea/

# Optional: keep VS Code workspace settings if you want
# !.vscode/settings.json

# -----------------------------------------------------------------------------
# Jupyter / notebooks
# -----------------------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb

# -----------------------------------------------------------------------------
# Build / packaging
# -----------------------------------------------------------------------------
build/
dist/
*.spec

# -----------------------------------------------------------------------------
# Cache / testing
# -----------------------------------------------------------------------------
.cache/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# -----------------------------------------------------------------------------
# Temporary files
# -----------------------------------------------------------------------------
tmp/
temp/
*.tmp
*.bak
*.old